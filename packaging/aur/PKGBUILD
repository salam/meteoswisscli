# Maintainer: salam <salam@users.noreply.github.com>
pkgname=meteoswisscli
pkgver=0.1.0
pkgrel=1
pkgdesc='CLI tools for Swiss weather and avalanche data from MeteoSwiss and SLF/WSL'
arch=('x86_64' 'aarch64')
url='https://github.com/salam/meteoswisscli'
license=('MIT')
makedepends=('go>=1.25')
source=("${pkgname}-${pkgver}.tar.gz::${url}/archive/v${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${pkgname}-${pkgver}"
  export CGO_CPPFLAGS="${CPPFLAGS}"
  export CGO_CFLAGS="${CFLAGS}"
  export CGO_CXXFLAGS="${CXXFLAGS}"
  export CGO_LDFLAGS="${LDFLAGS}"
  export GOFLAGS="-buildmode=pie -trimpath -ldflags=-linkmode=external -mod=readonly -modcacherw"

  _module=$(head -1 go.mod | awk '{print $2}')

  go build -ldflags "-s -w -X '${_module}/internal/meteoswiss/cmd.version=${pkgver}'" \
    -o meteoswiss ./cmd/meteoswiss
  go build -ldflags "-s -w -X '${_module}/internal/whiterisk/cmd.version=${pkgver}'" \
    -o whiterisk ./cmd/whiterisk

  # Generate shell completions
  ./meteoswiss completion bash > meteoswiss.bash
  ./meteoswiss completion zsh > _meteoswiss
  ./meteoswiss completion fish > meteoswiss.fish
  ./whiterisk completion bash > whiterisk.bash
  ./whiterisk completion zsh > _whiterisk
  ./whiterisk completion fish > whiterisk.fish
}

package() {
  cd "${pkgname}-${pkgver}"

  install -Dm755 meteoswiss "${pkgdir}/usr/bin/meteoswiss"
  install -Dm755 whiterisk "${pkgdir}/usr/bin/whiterisk"
  install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"

  # Shell completions
  install -Dm644 meteoswiss.bash "${pkgdir}/usr/share/bash-completion/completions/meteoswiss"
  install -Dm644 _meteoswiss "${pkgdir}/usr/share/zsh/site-functions/_meteoswiss"
  install -Dm644 meteoswiss.fish "${pkgdir}/usr/share/fish/vendor_completions.d/meteoswiss.fish"
  install -Dm644 whiterisk.bash "${pkgdir}/usr/share/bash-completion/completions/whiterisk"
  install -Dm644 _whiterisk "${pkgdir}/usr/share/zsh/site-functions/_whiterisk"
  install -Dm644 whiterisk.fish "${pkgdir}/usr/share/fish/vendor_completions.d/whiterisk.fish"
}
